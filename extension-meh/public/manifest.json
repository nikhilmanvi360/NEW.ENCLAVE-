{
  "manifest_version": 3,
  "name": "Fact Check AI",
  "version": "1.0",
  "description": "Real-time AI fact-checking engine.",
  "action": {
    "default_popup": "index.html",
    "default_title": "Fact Check Text"
  },
  "permissions": [
    "activeTab"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ]
}
